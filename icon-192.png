<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FAST Athletics — Admin Panel</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --black:#0a0a0a; --white:#fff; --gold:#f0c040; --gold-dark:#c99a1a;
  --gray:#1c1c1c; --gray2:#252525; --muted:#888; --border:#2a2a2a;
  --red:#e05555; --green:#4caf7d;
}
*{ box-sizing:border-box; margin:0; padding:0; }
body{ background:var(--black); color:var(--white); font-family:'Barlow',sans-serif; min-height:100vh; }

/* ── LOGIN ── */
#login-screen{
  min-height:100vh; display:flex; align-items:center; justify-content:center;
  background:radial-gradient(ellipse at center, #1a1400 0%, var(--black) 70%);
}
.login-box{
  width:100%; max-width:360px; padding:0 24px;
  display:flex; flex-direction:column; align-items:center;
}
.login-box img{ width:200px; margin-bottom:32px; }
.login-box h2{
  font-family:'Barlow Condensed',sans-serif; font-size:22px;
  font-weight:800; text-transform:uppercase; letter-spacing:2px;
  color:var(--muted); margin-bottom:24px;
}
.login-field{ width:100%; margin-bottom:14px; }
.login-field input{
  width:100%; background:var(--gray); border:1px solid var(--border);
  border-radius:8px; padding:14px 16px; font-size:15px;
  color:var(--white); outline:none; font-family:'Barlow',sans-serif;
  transition:border-color 0.2s;
}
.login-field input:focus{ border-color:var(--gold); }
.login-btn{
  width:100%; background:var(--gold); color:var(--black);
  font-family:'Barlow Condensed',sans-serif; font-weight:900;
  font-size:16px; letter-spacing:2px; text-transform:uppercase;
  padding:15px; border-radius:8px; border:none; cursor:pointer;
  transition:background 0.2s; margin-top:4px;
}
.login-btn:hover{ background:var(--gold-dark); }
.login-error{
  display:none; margin-top:12px; font-size:13px; color:var(--red);
  text-align:center;
}

/* ── ADMIN SHELL ── */
#admin-shell{ display:none; min-height:100vh; }

.admin-header{
  background:#0f0f0f; border-bottom:1px solid var(--border);
  padding:0 24px; height:64px;
  display:flex; align-items:center; justify-content:space-between;
  position:sticky; top:0; z-index:100;
}
.admin-header img{ height:36px; }
.admin-header-right{ display:flex; align-items:center; gap:16px; }
.admin-header-right span{ font-size:12px; color:var(--muted); letter-spacing:1px; text-transform:uppercase; }
.logout-btn{
  background:transparent; border:1px solid var(--border);
  color:var(--muted); font-family:'Barlow Condensed',sans-serif;
  font-size:13px; font-weight:700; letter-spacing:1px; text-transform:uppercase;
  padding:7px 14px; border-radius:6px; cursor:pointer; transition:all 0.2s;
}
.logout-btn:hover{ border-color:var(--red); color:var(--red); }

.admin-body{ display:flex; min-height:calc(100vh - 64px); }

/* ── SIDEBAR ── */
.sidebar{
  width:220px; flex-shrink:0; background:#0d0d0d;
  border-right:1px solid var(--border); padding:20px 0;
  position:sticky; top:64px; height:calc(100vh - 64px);
  overflow-y:auto;
}
.sidebar-section{
  font-size:10px; letter-spacing:2px; text-transform:uppercase;
  color:#444; padding:16px 20px 8px; font-family:'Barlow Condensed',sans-serif;
}
.sidebar-item{
  display:flex; align-items:center; gap:10px;
  padding:11px 20px; cursor:pointer; font-size:14px;
  color:var(--muted); transition:all 0.15s; border:none;
  background:transparent; width:100%; text-align:left;
  font-family:'Barlow',sans-serif;
}
.sidebar-item:hover{ color:var(--white); background:#151515; }
.sidebar-item.active{ color:var(--gold); background:#1a1400; border-right:2px solid var(--gold); }
.sidebar-item .si-icon{ font-size:16px; flex-shrink:0; }

/* ── CONTENT ── */
.admin-content{ flex:1; padding:32px; max-width:900px; }

.panel{ display:none; }
.panel.active{ display:block; }

.panel-title{
  font-family:'Barlow Condensed',sans-serif; font-size:28px;
  font-weight:900; text-transform:uppercase; letter-spacing:1px;
  margin-bottom:6px;
}
.panel-title span{ color:var(--gold); }
.panel-subtitle{ font-size:13px; color:var(--muted); margin-bottom:28px; line-height:1.5; }

/* ── CARDS / FORMS ── */
.admin-card{
  background:var(--gray); border:1px solid var(--border);
  border-radius:12px; padding:24px; margin-bottom:16px;
}
.admin-card-title{
  font-family:'Barlow Condensed',sans-serif; font-size:16px;
  font-weight:800; text-transform:uppercase; letter-spacing:0.5px;
  margin-bottom:18px; color:var(--white);
  display:flex; justify-content:space-between; align-items:center;
}
.form-grid{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.form-grid.col3{ grid-template-columns:1fr 1fr 1fr; }
.form-grid.col1{ grid-template-columns:1fr; }
@media(max-width:600px){ .form-grid,.form-grid.col3{ grid-template-columns:1fr; } }
.field{ display:flex; flex-direction:column; gap:6px; }
.field label{
  font-size:11px; letter-spacing:1.5px; text-transform:uppercase;
  color:var(--muted); font-family:'Barlow Condensed',sans-serif;
}
.field input,.field select,.field textarea{
  background:#2a2a2a; border:1px solid #333; border-radius:7px;
  padding:11px 13px; font-size:14px; color:var(--white);
  font-family:'Barlow',sans-serif; outline:none; transition:border-color 0.2s;
  -webkit-appearance:none;
}
.field input:focus,.field select:focus,.field textarea:focus{ border-color:var(--gold); }
.field select option{ background:#2a2a2a; }
.field textarea{ height:80px; resize:vertical; }

/* ── BUTTONS ── */
.btn{
  font-family:'Barlow Condensed',sans-serif; font-weight:800;
  font-size:13px; letter-spacing:1.5px; text-transform:uppercase;
  padding:10px 20px; border-radius:7px; border:none; cursor:pointer;
  transition:all 0.2s; display:inline-flex; align-items:center; gap:6px;
}
.btn-gold{ background:var(--gold); color:var(--black); }
.btn-gold:hover{ background:var(--gold-dark); }
.btn-red{ background:rgba(224,85,85,0.12); color:var(--red); border:1px solid rgba(224,85,85,0.25); }
.btn-red:hover{ background:rgba(224,85,85,0.2); }
.btn-ghost{ background:transparent; color:var(--muted); border:1px solid var(--border); }
.btn-ghost:hover{ border-color:var(--gold); color:var(--gold); }
.btn-sm{ padding:7px 14px; font-size:12px; }
.btn-row{ display:flex; gap:10px; margin-top:18px; flex-wrap:wrap; }

/* ── ITEM LIST ── */
.item-list{ display:flex; flex-direction:column; gap:10px; margin-bottom:20px; }
.item-row{
  display:flex; align-items:center; justify-content:space-between;
  background:#222; border:1px solid var(--border); border-radius:9px;
  padding:14px 16px; gap:12px;
}
.item-row-info{ flex:1; min-width:0; }
.item-row-title{
  font-family:'Barlow Condensed',sans-serif; font-size:15px;
  font-weight:700; text-transform:uppercase; white-space:nowrap;
  overflow:hidden; text-overflow:ellipsis;
}
.item-row-sub{ font-size:12px; color:var(--muted); margin-top:2px; }
.item-row-actions{ display:flex; gap:8px; flex-shrink:0; }

/* ── TOAST ── */
#toast{
  position:fixed; bottom:24px; left:50%; transform:translateX(-50%);
  background:var(--green); color:#fff; padding:12px 24px;
  border-radius:8px; font-family:'Barlow Condensed',sans-serif;
  font-size:14px; font-weight:700; letter-spacing:1px; text-transform:uppercase;
  z-index:999; opacity:0; transition:opacity 0.3s; pointer-events:none;
  white-space:nowrap;
}

/* ── BADGE PREVIEW ── */
.badge-prev{
  display:inline-block; padding:2px 8px; border-radius:4px;
  font-size:10px; font-weight:600; letter-spacing:1px;
  text-transform:uppercase; margin-left:8px;
}

/* ── DIVIDER ── */
.divider{ height:1px; background:var(--border); margin:20px 0; }

/* ── MOBILE ── */
@media(max-width:768px){
  .sidebar{ display:none; }
  .admin-content{ padding:20px 16px; }
}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <img src="data:image/png;base64," alt="FAST Athletics">
    <h2>Admin Panel</h2>
    <div class="login-field">
      <input type="password" id="login-pw" placeholder="Enter password" onkeydown="if(event.key==='Enter')doLogin()">
    </div>
    <button class="login-btn" onclick="doLogin()">Log In</button>
    <div class="login-error" id="login-error">Incorrect password. Try again.</div>
  </div>
</div>

<!-- ADMIN SHELL -->
<div id="admin-shell">
  <div class="admin-header">
    <img src="data:image/png;base64," alt="FAST Athletics">
    <div class="admin-header-right">
      <span>Admin Panel</span>
      <button class="logout-btn" onclick="doLogout()">Log Out</button>
    </div>
  </div>

  <div class="admin-body">
    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sidebar-section">Content</div>
      <button class="sidebar-item active" onclick="showPanel('settings')" id="sb-settings">
        <span class="si-icon">⚙️</span> General
      </button>
      <button class="sidebar-item" onclick="showPanel('schedule')" id="sb-schedule">
        <span class="si-icon">📅</span> Schedule
      </button>
      <button class="sidebar-item" onclick="showPanel('events')" id="sb-events">
        <span class="si-icon">🎉</span> Events
      </button>
      <button class="sidebar-item" onclick="showPanel('coaches')" id="sb-coaches">
        <span class="si-icon">👟</span> Coaches
      </button>
      <button class="sidebar-item" onclick="showPanel('media')" id="sb-media">
        <span class="si-icon">📸</span> Media
      </button>
      <div class="sidebar-section" style="margin-top:8px;">App</div>
      <button class="sidebar-item" onclick="window.open('/','_blank')" id="sb-view">
        <span class="si-icon">👁</span> View App
      </button>
    </div>

    <!-- CONTENT -->
    <div class="admin-content">

      <!-- ═══ SETTINGS ═══ -->
      <div class="panel active" id="panel-settings">
        <div class="panel-title">General <span>Settings</span></div>
        <div class="panel-subtitle">Update the next meet info, join notice, and uniform order status shown in the app.</div>

        <div class="admin-card">
          <div class="admin-card-title">🏠 Home Page — Next Meet</div>
          <div class="form-grid">
            <div class="field"><label>Meet Name</label><input id="s-next-name" placeholder="e.g. Port City S-P-E-E-D Relays"></div>
            <div class="field"><label>Date</label><input id="s-next-date" placeholder="e.g. May 23, 2026"></div>
          </div>
          <div class="form-grid col1" style="margin-top:14px;">
            <div class="field"><label>Location</label><input id="s-next-loc" placeholder="e.g. Jacksonville, AR"></div>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-card-title">⚡ Join Page Notice</div>
          <div class="form-grid col1">
            <div class="field"><label>Notice Message</label><input id="s-join-notice" placeholder="e.g. ⚠️ Registration is currently closed for the 2026 AAU season."></div>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-card-title">👕 Uniform Order Status</div>
          <div class="form-grid col1">
            <div class="field"><label>Order Status Message</label><input id="s-order-status" placeholder="e.g. ⚠️ Orders are currently closed for the season."></div>
          </div>
        </div>

        <div class="btn-row">
          <button class="btn btn-gold" onclick="saveSettings()">💾 Save Settings</button>
        </div>
      </div>

      <!-- ═══ SCHEDULE ═══ -->
      <div class="panel" id="panel-schedule">
        <div class="panel-title">2026 <span>Schedule</span></div>
        <div class="panel-subtitle">Add, edit, or remove meets. Changes appear instantly in the app.</div>

        <div class="item-list" id="schedule-list"></div>

        <div class="admin-card" id="schedule-form-card">
          <div class="admin-card-title" id="schedule-form-title">➕ Add New Meet</div>
          <div class="form-grid">
            <div class="field"><label>Meet Name</label><input id="sc-title" placeholder="e.g. AAU District Meet"></div>
            <div class="field"><label>Date</label><input id="sc-date" placeholder="e.g. 6/12"></div>
          </div>
          <div class="form-grid" style="margin-top:14px;">
            <div class="field"><label>Year</label><input id="sc-year" placeholder="2026" value="2026"></div>
            <div class="field"><label>Status</label>
              <select id="sc-status" onchange="toggleResultsField()">
                <option value="upcoming">Upcoming</option>
                <option value="results">Results Available</option>
                <option value="major">Major (AAU/Regional/Nationals)</option>
              </select>
            </div>
          </div>
          <div class="form-grid col1" style="margin-top:14px;">
            <div class="field"><label>Location</label><input id="sc-location" placeholder="e.g. 2901 Leopard Dr, Texarkana, AR"></div>
          </div>
          <div class="form-grid" style="margin-top:14px;" id="sc-extra-fields">
            <div class="field" id="sc-badge-wrap"><label>Badge Label</label><input id="sc-badge" placeholder="e.g. AAU, Regional, 🏆 Nationals"></div>
            <div class="field" id="sc-results-wrap" style="display:none;"><label>Results Link</label><input id="sc-results" placeholder="https://athletic.net/..."></div>
          </div>
          <div class="btn-row">
            <button class="btn btn-gold" onclick="saveMeet()">💾 Save Meet</button>
            <button class="btn btn-ghost" onclick="cancelMeetEdit()">Cancel</button>
          </div>
        </div>
      </div>

      <!-- ═══ EVENTS ═══ -->
      <div class="panel" id="panel-events">
        <div class="panel-title">Team <span>Events</span></div>
        <div class="panel-subtitle">Add banquets, fundraisers, and community events.</div>

        <div class="item-list" id="events-list"></div>

        <div class="admin-card">
          <div class="admin-card-title" id="events-form-title">➕ Add New Event</div>
          <div class="form-grid">
            <div class="field"><label>Event Name</label><input id="ev-title" placeholder="e.g. Athletic Banquet"></div>
            <div class="field"><label>Month (3 letters)</label><input id="ev-month" placeholder="e.g. AUG" maxlength="3" style="text-transform:uppercase;"></div>
          </div>
          <div class="form-grid" style="margin-top:14px;">
            <div class="field"><label>Day</label><input id="ev-day" placeholder="e.g. 15 or TBD"></div>
            <div class="field"><label>Time</label><input id="ev-time" placeholder="e.g. 6:00 PM or TBD"></div>
          </div>
          <div class="form-grid col1" style="margin-top:14px;">
            <div class="field"><label>Location</label><input id="ev-location" placeholder="e.g. Bryant Community Center, Bryant AR"></div>
          </div>
          <div class="form-grid col1" style="margin-top:14px;">
            <div class="field"><label>Description</label><textarea id="ev-desc" placeholder="e.g. Join us to celebrate our athletes and the 2026 season!"></textarea></div>
          </div>
          <div class="form-grid col1" style="margin-top:14px;">
            <div class="field"><label>Tag / Badge (optional)</label><input id="ev-tag" placeholder="e.g. Free Admission, RSVP Required"></div>
          </div>
          <div class="btn-row">
            <button class="btn btn-gold" onclick="saveEvent()">💾 Save Event</button>
            <button class="btn btn-ghost" onclick="cancelEventEdit()">Cancel</button>
          </div>
        </div>
      </div>

      <!-- ═══ COACHES ═══ -->
      <div class="panel" id="panel-coaches">
        <div class="panel-title">Coaching <span>Staff</span></div>
        <div class="panel-subtitle">Manage coaches and executive board members shown on the About page.</div>

        <div class="admin-card">
          <div class="admin-card-title">👟 Coaching Staff</div>
          <div class="item-list" id="coaches-list"></div>
        </div>

        <div class="admin-card">
          <div class="admin-card-title">🏆 Executive Board</div>
          <div class="item-list" id="board-list"></div>
        </div>

        <div class="admin-card">
          <div class="admin-card-title" id="coaches-form-title">➕ Add Person</div>
          <div class="form-grid">
            <div class="field"><label>Full Name</label><input id="co-name" placeholder="e.g. Coach Kendrick Farr"></div>
            <div class="field"><label>Role / Title</label><input id="co-role" placeholder="e.g. Athletic Director / Head Coach"></div>
          </div>
          <div class="form-grid" style="margin-top:14px;">
            <div class="field"><label>Initials (2 letters)</label><input id="co-initials" placeholder="e.g. KF" maxlength="3" style="text-transform:uppercase;"></div>
            <div class="field"><label>Section</label>
              <select id="co-section">
                <option value="coach">Coaching Staff</option>
                <option value="board">Executive Board</option>
              </select>
            </div>
          </div>
          <div class="btn-row">
            <button class="btn btn-gold" onclick="savePerson()">💾 Save Person</button>
            <button class="btn btn-ghost" onclick="cancelCoachEdit()">Cancel</button>
          </div>
        </div>
      </div>

      <!-- ═══ MEDIA ═══ -->
      <div class="panel" id="panel-media">
        <div class="panel-title">FAST <span>Media</span></div>
        <div class="panel-subtitle">Add meet galleries and community videos shown on the Media page.</div>

        <div class="item-list" id="media-list"></div>

        <div class="admin-card">
          <div class="admin-card-title" id="media-form-title">➕ Add Media</div>
          <div class="form-grid">
            <div class="field"><label>Title</label><input id="me-title" placeholder="e.g. AAU District Meet Gallery"></div>
            <div class="field"><label>Type</label>
              <select id="me-type">
                <option value="gallery">📸 Photo Gallery</option>
                <option value="video">🎬 Video</option>
              </select>
            </div>
          </div>
          <div class="form-grid col1" style="margin-top:14px;">
            <div class="field"><label>Date / Subtitle</label><input id="me-subtitle" placeholder="e.g. June 12, 2026 · Texarkana, AR"></div>
          </div>
          <div class="form-grid col1" style="margin-top:14px;">
            <div class="field"><label>Link URL</label><input id="me-link" placeholder="https://..."></div>
          </div>
          <div class="form-grid" style="margin-top:14px;">
            <div class="field"><label>Thumbnail URL (videos only)</label><input id="me-thumb" placeholder="https://... (optional)"></div>
            <div class="field"><label>Duration (videos only)</label><input id="me-duration" placeholder="e.g. 2:20"></div>
          </div>
          <div class="btn-row">
            <button class="btn btn-gold" onclick="saveMedia()">💾 Save Media</button>
            <button class="btn btn-ghost" onclick="cancelMediaEdit()">Cancel</button>
          </div>
        </div>
      </div>

    </div><!-- /admin-content -->
  </div><!-- /admin-body -->
</div><!-- /admin-shell -->

<div id="toast">✅ Saved!</div>

<script>
// ══════════════════════════════════════════
//  FAST Athletics Admin Panel
//  Password-protected. All data stored in
//  localStorage and read by the app on load.
// ══════════════════════════════════════════

const ADMIN_PASSWORD = 'FAST2026!';
const STORE_KEY = 'fast_cms';

// ── Auth ──
function doLogin() {
  const pw = document.getElementById('login-pw').value;
  if (pw === ADMIN_PASSWORD) {
    sessionStorage.setItem('fast_admin', '1');
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('admin-shell').style.display = 'block';
    loadAll();
  } else {
    document.getElementById('login-error').style.display = 'block';
    document.getElementById('login-pw').value = '';
  }
}

function doLogout() {
  sessionStorage.removeItem('fast_admin');
  location.reload();
}

if (sessionStorage.getItem('fast_admin')) {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('admin-shell').style.display = 'block';
}

// ── Storage helpers ──
function getData() { return JSON.parse(localStorage.getItem(STORE_KEY) || '{}'); }
function setData(d) { localStorage.setItem(STORE_KEY, JSON.stringify(d)); }

// ── Toast ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = '✅ ' + msg;
  t.style.opacity = '1';
  setTimeout(() => t.style.opacity = '0', 2500);
}

// ── Panel navigation ──
function showPanel(name) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sidebar-item').forEach(s => s.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  document.getElementById('sb-' + name).classList.add('active');
}

// ── Load all data into UI ──
function loadAll() {
  const d = getData();
  if (d.settings) loadSettings(d.settings);
  renderSchedule(d.schedule || []);
  renderEvents(d.events || []);
  renderCoaches(d.coaches || []);
  renderMedia(d.media || []);
}

// ══ SETTINGS ══
function loadSettings(s) {
  if (s.next_meet_name) document.getElementById('s-next-name').value = s.next_meet_name;
  if (s.next_meet_date) document.getElementById('s-next-date').value = s.next_meet_date;
  if (s.next_meet_location) document.getElementById('s-next-loc').value = s.next_meet_location;
  if (s.join_notice) document.getElementById('s-join-notice').value = s.join_notice;
  if (s.order_status) document.getElementById('s-order-status').value = s.order_status;
}

function saveSettings() {
  const d = getData();
  d.settings = {
    next_meet_name: document.getElementById('s-next-name').value,
    next_meet_date: document.getElementById('s-next-date').value,
    next_meet_location: document.getElementById('s-next-loc').value,
    join_notice: document.getElementById('s-join-notice').value,
    order_status: document.getElementById('s-order-status').value,
  };
  setData(d);
  showToast('Settings saved!');
}

// ══ SCHEDULE ══
let editingMeetIdx = -1;

function renderSchedule(list) {
  const el = document.getElementById('schedule-list');
  if (list.length === 0) { el.innerHTML = '<div style="color:var(--muted);font-size:14px;padding:8px 0;">No meets added yet.</div>'; return; }
  el.innerHTML = list.map((m, i) => `
    <div class="item-row">
      <div class="item-row-info">
        <div class="item-row-title">${m.date} — ${m.title}</div>
        <div class="item-row-sub">${m.location}</div>
      </div>
      <div class="item-row-actions">
        <button class="btn btn-ghost btn-sm" onclick="editMeet(${i})">✏️ Edit</button>
        <button class="btn btn-red btn-sm" onclick="deleteMeet(${i})">🗑 Delete</button>
      </div>
    </div>`).join('');
}

function toggleResultsField() {
  const status = document.getElementById('sc-status').value;
  document.getElementById('sc-results-wrap').style.display = status === 'results' ? 'block' : 'none';
  document.getElementById('sc-badge-wrap').style.display = status === 'major' ? 'block' : 'none';
}

function saveMeet() {
  const title = document.getElementById('sc-title').value.trim();
  const date = document.getElementById('sc-date').value.trim();
  if (!title || !date) { alert('Please enter at least a meet name and date.'); return; }
  const meet = {
    title, date,
    year: document.getElementById('sc-year').value || '2026',
    location: document.getElementById('sc-location').value.trim(),
    status: document.getElementById('sc-status').value,
    badge_label: document.getElementById('sc-badge').value.trim(),
    results_link: document.getElementById('sc-results').value.trim(),
  };
  const d = getData();
  if (!d.schedule) d.schedule = [];
  if (editingMeetIdx >= 0) { d.schedule[editingMeetIdx] = meet; }
  else { d.schedule.push(meet); }
  setData(d);
  renderSchedule(d.schedule);
  cancelMeetEdit();
  showToast('Meet saved!');
}

function editMeet(i) {
  const d = getData();
  const m = d.schedule[i];
  editingMeetIdx = i;
  document.getElementById('sc-title').value = m.title;
  document.getElementById('sc-date').value = m.date;
  document.getElementById('sc-year').value = m.year || '2026';
  document.getElementById('sc-location').value = m.location;
  document.getElementById('sc-status').value = m.status;
  document.getElementById('sc-badge').value = m.badge_label || '';
  document.getElementById('sc-results').value = m.results_link || '';
  toggleResultsField();
  document.getElementById('schedule-form-title').textContent = '✏️ Edit Meet';
  document.getElementById('schedule-form-card').scrollIntoView({behavior:'smooth'});
}

function deleteMeet(i) {
  if (!confirm('Delete this meet?')) return;
  const d = getData();
  d.schedule.splice(i, 1);
  setData(d);
  renderSchedule(d.schedule);
  showToast('Meet deleted.');
}

function cancelMeetEdit() {
  editingMeetIdx = -1;
  ['sc-title','sc-date','sc-year','sc-location','sc-badge','sc-results'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('sc-year').value = '2026';
  document.getElementById('sc-status').value = 'upcoming';
  document.getElementById('schedule-form-title').textContent = '➕ Add New Meet';
  toggleResultsField();
}

// ══ EVENTS ══
let editingEventIdx = -1;

function renderEvents(list) {
  const el = document.getElementById('events-list');
  if (list.length === 0) { el.innerHTML = '<div style="color:var(--muted);font-size:14px;padding:8px 0;">No events added yet.</div>'; return; }
  el.innerHTML = list.map((e, i) => `
    <div class="item-row">
      <div class="item-row-info">
        <div class="item-row-title">${e.month} ${e.day} — ${e.title}</div>
        <div class="item-row-sub">${e.location || ''}${e.time ? ' · ' + e.time : ''}</div>
      </div>
      <div class="item-row-actions">
        <button class="btn btn-ghost btn-sm" onclick="editEvent(${i})">✏️ Edit</button>
        <button class="btn btn-red btn-sm" onclick="deleteEvent(${i})">🗑 Delete</button>
      </div>
    </div>`).join('');
}

function saveEvent() {
  const title = document.getElementById('ev-title').value.trim();
  const month = document.getElementById('ev-month').value.trim().toUpperCase();
  const day = document.getElementById('ev-day').value.trim();
  if (!title || !month) { alert('Please enter at least an event name and month.'); return; }
  const event = {
    title, month, day,
    time: document.getElementById('ev-time').value.trim(),
    location: document.getElementById('ev-location').value.trim(),
    description: document.getElementById('ev-desc').value.trim(),
    tag: document.getElementById('ev-tag').value.trim(),
  };
  const d = getData();
  if (!d.events) d.events = [];
  if (editingEventIdx >= 0) { d.events[editingEventIdx] = event; }
  else { d.events.push(event); }
  setData(d);
  renderEvents(d.events);
  cancelEventEdit();
  showToast('Event saved!');
}

function editEvent(i) {
  const d = getData();
  const e = d.events[i];
  editingEventIdx = i;
  document.getElementById('ev-title').value = e.title;
  document.getElementById('ev-month').value = e.month;
  document.getElementById('ev-day').value = e.day;
  document.getElementById('ev-time').value = e.time || '';
  document.getElementById('ev-location').value = e.location || '';
  document.getElementById('ev-desc').value = e.description || '';
  document.getElementById('ev-tag').value = e.tag || '';
  document.getElementById('events-form-title').textContent = '✏️ Edit Event';
}

function deleteEvent(i) {
  if (!confirm('Delete this event?')) return;
  const d = getData();
  d.events.splice(i, 1);
  setData(d);
  renderEvents(d.events);
  showToast('Event deleted.');
}

function cancelEventEdit() {
  editingEventIdx = -1;
  ['ev-title','ev-month','ev-day','ev-time','ev-location','ev-desc','ev-tag'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('events-form-title').textContent = '➕ Add New Event';
}

// ══ COACHES ══
let editingCoachIdx = -1;

function renderCoaches(list) {
  const coaches = list.filter(c => c.section === 'coach');
  const board = list.filter(c => c.section === 'board');
  const renderList = (items, startIdx, elId) => {
    const el = document.getElementById(elId);
    if (items.length === 0) { el.innerHTML = '<div style="color:var(--muted);font-size:14px;padding:8px 0;">None added yet.</div>'; return; }
    el.innerHTML = items.map((c, i) => `
      <div class="item-row">
        <div style="width:36px;height:36px;border-radius:50%;background:#2a2a2a;border:2px solid #333;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;color:var(--gold);flex-shrink:0;">${c.initials}</div>
        <div class="item-row-info" style="margin-left:12px;">
          <div class="item-row-title">${c.name}</div>
          <div class="item-row-sub">${c.role}</div>
        </div>
        <div class="item-row-actions">
          <button class="btn btn-ghost btn-sm" onclick="editPerson(${startIdx + i})">✏️</button>
          <button class="btn btn-red btn-sm" onclick="deletePerson(${startIdx + i})">🗑</button>
        </div>
      </div>`).join('');
  };
  renderList(coaches, 0, 'coaches-list');
  renderList(board, coaches.length, 'board-list');
}

function savePerson() {
  const name = document.getElementById('co-name').value.trim();
  const role = document.getElementById('co-role').value.trim();
  if (!name || !role) { alert('Please enter a name and role.'); return; }
  const person = {
    name, role,
    initials: document.getElementById('co-initials').value.trim().toUpperCase().slice(0,3),
    section: document.getElementById('co-section').value,
  };
  const d = getData();
  if (!d.coaches) d.coaches = [];
  if (editingCoachIdx >= 0) { d.coaches[editingCoachIdx] = person; }
  else { d.coaches.push(person); }
  setData(d);
  renderCoaches(d.coaches);
  cancelCoachEdit();
  showToast('Person saved!');
}

function editPerson(i) {
  const d = getData();
  const c = d.coaches[i];
  editingCoachIdx = i;
  document.getElementById('co-name').value = c.name;
  document.getElementById('co-role').value = c.role;
  document.getElementById('co-initials').value = c.initials;
  document.getElementById('co-section').value = c.section;
  document.getElementById('coaches-form-title').textContent = '✏️ Edit Person';
}

function deletePerson(i) {
  if (!confirm('Remove this person?')) return;
  const d = getData();
  d.coaches.splice(i, 1);
  setData(d);
  renderCoaches(d.coaches);
  showToast('Person removed.');
}

function cancelCoachEdit() {
  editingCoachIdx = -1;
  ['co-name','co-role','co-initials'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('co-section').value = 'coach';
  document.getElementById('coaches-form-title').textContent = '➕ Add Person';
}

// ══ MEDIA ══
let editingMediaIdx = -1;

function renderMedia(list) {
  const el = document.getElementById('media-list');
  if (list.length === 0) { el.innerHTML = '<div style="color:var(--muted);font-size:14px;padding:8px 0;">No media added yet.</div>'; return; }
  el.innerHTML = list.map((m, i) => `
    <div class="item-row">
      <div style="font-size:20px;flex-shrink:0;">${m.type === 'video' ? '🎬' : '📸'}</div>
      <div class="item-row-info" style="margin-left:12px;">
        <div class="item-row-title">${m.title}</div>
        <div class="item-row-sub">${m.subtitle}</div>
      </div>
      <div class="item-row-actions">
        <button class="btn btn-ghost btn-sm" onclick="editMedia(${i})">✏️ Edit</button>
        <button class="btn btn-red btn-sm" onclick="deleteMedia(${i})">🗑 Delete</button>
      </div>
    </div>`).join('');
}

function saveMedia() {
  const title = document.getElementById('me-title').value.trim();
  const link = document.getElementById('me-link').value.trim();
  if (!title || !link) { alert('Please enter a title and link.'); return; }
  const item = {
    title, link,
    type: document.getElementById('me-type').value,
    subtitle: document.getElementById('me-subtitle').value.trim(),
    thumbnail: document.getElementById('me-thumb').value.trim(),
    duration: document.getElementById('me-duration').value.trim(),
  };
  const d = getData();
  if (!d.media) d.media = [];
  if (editingMediaIdx >= 0) { d.media[editingMediaIdx] = item; }
  else { d.media.push(item); }
  setData(d);
  renderMedia(d.media);
  cancelMediaEdit();
  showToast('Media saved!');
}

function editMedia(i) {
  const d = getData();
  const m = d.media[i];
  editingMediaIdx = i;
  document.getElementById('me-title').value = m.title;
  document.getElementById('me-type').value = m.type;
  document.getElementById('me-subtitle').value = m.subtitle || '';
  document.getElementById('me-link').value = m.link;
  document.getElementById('me-thumb').value = m.thumbnail || '';
  document.getElementById('me-duration').value = m.duration || '';
  document.getElementById('media-form-title').textContent = '✏️ Edit Media';
}

function deleteMedia(i) {
  if (!confirm('Delete this media item?')) return;
  const d = getData();
  d.media.splice(i, 1);
  setData(d);
  renderMedia(d.media);
  showToast('Media deleted.');
}

function cancelMediaEdit() {
  editingMediaIdx = -1;
  ['me-title','me-subtitle','me-link','me-thumb','me-duration'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('me-type').value = 'gallery';
  document.getElementById('media-form-title').textContent = '➕ Add Media';
}

// Load on start if already logged in
if (sessionStorage.getItem('fast_admin')) loadAll();
</script>
</body>
</html>